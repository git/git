msgstr "காண்க"

msgid "&About gitk"
msgstr "அறிவிலிகே பற்றி"

msgid "&Key bindings"
msgstr "முக்கிய பிணைப்புகள்"

msgid "&Help"
msgstr "உதவி"

msgid "Commit ID:"
msgstr "உறுதிமொழி அடையாளம்:"

